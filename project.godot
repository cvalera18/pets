; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Pets"
config/description="A cozy virtual pet experience"
run/main_scene="res://scenes/main/Main.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://autoloads/EventBus.gd"
GameConfig="*res://autoloads/GameConfig.gd"
SaveSystem="*res://autoloads/SaveSystem.gd"
NotificationManager="*res://autoloads/NotificationManager.gd"

[display]

window/size/viewport_width=390
window/size/viewport_height=844
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[internationalization]

locale/translations=PackedStringArray("res://i18n/en.po", "res://i18n/es.po")
locale/fallback="en"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="mobile"
